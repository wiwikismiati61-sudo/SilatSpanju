{
  "entities": {
    "AppData": {
      "title": "AppData",
      "description": "The main data structure for the application, including students, attendance, and settings.",
      "type": "object",
      "properties": {
        "students": {
          "type": "array",
          "description": "List of students."
        },
        "attendance": {
          "type": "array",
          "description": "List of attendance records."
        },
        "settings": {
          "type": "object",
          "description": "Application settings."
        },
        "user": {
          "type": "object",
          "description": "User credentials for the operator."
        }
      },
      "required": ["students", "attendance", "settings", "user"]
    }
  },
  "firestore": {
    "/appData/main": {
      "schema": "AppData",
      "description": "The single document containing all application data."
    }
  }
}
